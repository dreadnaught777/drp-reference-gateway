{
  "name": "drp-reference-gateway",
  "version": "0.1.0",
  "description": "Reference implementation of Declarative Runtime Policy (DRP): an MCP-proxying policy gateway",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:rego": "bash scripts/build-rego.sh",
    "serve:gateway": "tsx scripts/claude-code-hook/serve.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@cedar-policy/cedar-wasm": "^4.11.1",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "ajv": "^8.20.0",
    "canonicalize": "^2.0.0",
    "yaml": "^2.6.0"
  }
}
